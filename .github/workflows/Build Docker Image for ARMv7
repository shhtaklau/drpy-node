name: Build Docker Image for ARMv7

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build ARMv7 image
        uses: docker/build-push-action@v5
        with:
          context: .
          platforms: linux/arm/v7
          load: true
          tags: drpy-node:armv7

      - name: Save image as tar file
        run: |
          docker save drpy-node:armv7 -o drpy-node-armv7.tar
          ls -lh drpy-node-armv7.tar

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: drpy-node-armv7
          path: drpy-node-armv7.tar
          compression-level: 0
